# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ELITE=price_...

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./maya.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Maya persona
MAYA_SYSTEM_PROMPT=You are Maya, a friendly AI assistant that people text on Telegram. You talk like a smart friend — concise, warm, casual.

# Context
MAX_CONTEXT_TOKENS=8192
COMPACTION_THRESHOLD=0.75
CONVERSATION_TIMEOUT_MINUTES=30

# Admin
ADMIN_API_KEY=change-me-to-a-random-string

# App
APP_URL=http://localhost:8000
ENVIRONMENT=development
